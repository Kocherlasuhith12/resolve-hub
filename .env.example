RH_ENVIRONMENT=local
RH_DEBUG=false
RH_DATABASE_URL=postgresql+asyncpg://resolvehub:change-me@localhost:5432/resolvehub
RH_REDIS_URL=redis://localhost:6379/0
RH_TEMPORAL_ADDRESS=localhost:7234
RH_TEMPORAL_PORT=7234
RH_TEMPORAL_NAMESPACE=default
RH_TEMPORAL_TASK_QUEUE=resolvehub-sla
RH_OUTBOX_BATCH_SIZE=50
RH_JWT_SECRET=replace-with-at-least-32-random-characters
RH_ACCESS_TOKEN_TTL_MINUTES=15
RH_REFRESH_TOKEN_TTL_DAYS=30
# Must be true in staging/production. False permits local HTTP browser development only.
RH_BROWSER_COOKIE_SECURE=false
RH_EMAIL_VERIFICATION_TTL_HOURS=24
# AI remains optional. The deterministic fake is the only provider currently implemented.
RH_AI_ENABLED=false
RH_AI_PROVIDER=fake
RH_AI_CONFIDENCE_THRESHOLD=0.65
RH_CORS_ORIGINS=["http://localhost:5173"]
# Integration tests must use a dedicated database.
RH_TEST_DATABASE_URL=postgresql+asyncpg://resolvehub:change-me@localhost:5432/resolvehub_tes